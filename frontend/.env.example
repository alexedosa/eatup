# ─── Data source ───────────────────────────────────────────────
# true  = mock fixtures, no backend needed (local UI development)
# false = live EatUp API (staging / production)
NEXT_PUBLIC_MOCK_VIEW=true

# Backend base URL (must include /api/v1)
NEXT_PUBLIC_API_BASE_URL=https://eatup-backend-byng.onrender.com/api/v1

# Where riders are sent after completing web signup
NEXT_PUBLIC_RIDER_APP_URL=https://eatup.app/download
